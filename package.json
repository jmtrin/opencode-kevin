{
	"name": "@jmtrin/opencode-kevin",
	"version": "0.2.0",
	"description": "Kevin — Observa y aprende: capa de aprendizaje para OpenCode",
	"type": "module",
	"main": "dist/plugin/index.js",
	"exports": {
		".": {
			"import": "./dist/plugin/index.js",
			"types": "./dist/plugin/index.d.ts"
		}
	},
	"files": ["dist/plugin", "dist/migrations", "migrations"],
	"scripts": {
		"build": "tsc --outDir dist && node scripts/copy-migrations.mjs",
		"prepublishOnly": "npm run build",
		"test": "vitest run",
		"test:unit": "vitest run tests/unit",
		"test:integration": "vitest run tests/integration",
		"test:e2e": "vitest run tests/e2e",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"format": "biome format --write .",
		"verify": "node --import tsx scripts/verify-install.ts"
	},
	"dependencies": {
		"@opencode-ai/plugin": "^1.17.6",
		"zod": "^3.23.8"
	},
	"optionalDependencies": {
		"better-sqlite3": "^12.11.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.0",
		"tsx": "^4.19.0",
		"typescript": "^5.7.2",
		"vitest": "^2.1.8"
	},
	"engines": {
		"node": ">=22.5.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT"
}
